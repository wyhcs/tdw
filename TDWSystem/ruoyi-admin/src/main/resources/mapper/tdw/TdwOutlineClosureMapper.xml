<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.tdw.mapper.TdwOutlineClosureMapper">
    
    <resultMap type="TdwOutlineClosure" id="TdwOutlineClosureResult">
        <result property="id"    column="id"    />
        <result property="ancestor"    column="ancestor"    />
        <result property="descendant"    column="descendant"    />
        <result property="depth"    column="depth"    />
    </resultMap>

    <sql id="selectTdwOutlineClosureVo">
        select id, ancestor, descendant, depth from tdw_outline_closure
    </sql>

    <select id="selectTdwOutlineClosureList" parameterType="TdwOutlineClosure" resultMap="TdwOutlineClosureResult">
        <include refid="selectTdwOutlineClosureVo"/>
        <where>  
            <if test="ancestor != null "> and ancestor = #{ancestor}</if>
            <if test="descendant != null "> and descendant = #{descendant}</if>
            <if test="depth != null "> and depth = #{depth}</if>
        </where>
    </select>
    
    <select id="selectTdwOutlineClosureById" parameterType="Long" resultMap="TdwOutlineClosureResult">
        <include refid="selectTdwOutlineClosureVo"/>
        where id = #{id}
    </select>


    <select id="selectAncestorByParentId" parameterType="Long" resultMap="TdwOutlineClosureResult">
        SELECT id, ancestor, descendant, depth FROM tdw_outline_closure WHERE descendant = #{descendant}
    </select>

    <select id="selectDescendantClosuresByAncestor" parameterType="Long" resultMap="TdwOutlineClosureResult">
        SELECT id, ancestor, descendant, depth FROM tdw_outline_closure WHERE ancestor = #{ancestor}
    </select>

    <select id="selectDescendantIdsByAncestor" parameterType="Long" resultType="Long">
        SELECT descendant FROM tdw_outline_closure WHERE ancestor = #{ancestor}
    </select>

    <insert id="insertTdwOutlineClosure" parameterType="TdwOutlineClosure" useGeneratedKeys="true" keyProperty="id">
        insert into tdw_outline_closure
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="ancestor != null">ancestor,</if>
            <if test="descendant != null">descendant,</if>
            <if test="depth != null">depth,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="ancestor != null">#{ancestor},</if>
            <if test="descendant != null">#{descendant},</if>
            <if test="depth != null">#{depth},</if>
         </trim>
    </insert>

    <insert id="batchInsert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO tdw_outline_closure(ancestor, descendant, depth) VALUES
        <foreach collection='list' item='item' separator=','>
            (#{item.ancestor}, #{item.descendant}, #{item.depth})
        </foreach>
    </insert>

    <insert id="insertOutlineClosureLeval1">
        INSERT INTO tdw_outline_closure(ancestor, descendant, depth) VALUES(#{outlineId}, #{outlineId}, 0);
    </insert>

    <insert id="insertOutlineClosureLeval2">
        INSERT INTO tdw_outline_closure(ancestor, descendant, depth) VALUES (#{outlineId}, #{outlineId}, 0), (#{parentId}, #{outlineId}, 1);
    </insert>

    <update id="updateTdwOutlineClosure" parameterType="TdwOutlineClosure">
        update tdw_outline_closure
        <trim prefix="SET" suffixOverrides=",">
            <if test="ancestor != null">ancestor = #{ancestor},</if>
            <if test="descendant != null">descendant = #{descendant},</if>
            <if test="depth != null">depth = #{depth},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTdwOutlineClosureById" parameterType="Long">
        delete from tdw_outline_closure where id = #{id}
    </delete>

    <delete id="batchDeleteByNodeIds" parameterType="Long">
        DELETE FROM tdw_outline_closure WHERE ancestor IN
        <foreach collection='list' item='id' open='(' separator=',' close=')'>
            #{id}
        </foreach>
        OR descendant IN
        <foreach collection='list' item='id' open='(' separator=',' close=')'>
           #{id}
        </foreach>
    </delete>

    <delete id="deleteExternalClosureByDescendantIds" parameterType="Long">
        DELETE FROM tdw_outline_closure
        WHERE descendant IN
        <foreach collection='list' item='id' open='(' separator=',' close=')'>
            #{id}
        </foreach>
        AND ancestor NOT IN
        <foreach collection='list' item='id' open='(' separator=',' close=')'>
            #{id}
        </foreach>
    </delete>

    <delete id="deleteTdwOutlineClosureByIds" parameterType="String">
        delete from tdw_outline_closure where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
