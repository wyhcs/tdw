    <update id="updateTdwOutlines" parameterType="TdwOutlines">
        update tdw_outlines
        <trim prefix="SET" suffixOverrides=",">
            <if test="bidId != null">bid_id = #{bidId},</if>
            <if test="parentId != null">parent_id = #{parentId},</if>
            <if test="level != null">level = #{level},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="sortNum != null">sort_num = #{sortNum},</if>
        </trim>
        where id = #{id}
    </update>

    <update id="updateOutlineTitle">
        update tdw_outlines set title = #{title} where id = #{id}
    </update>

    <update id="updateParentAndSort">
        update tdw_outlines
        set
        <choose>
            <when test="parentId != null">
                parent_id = #{parentId},
            </when>
            <otherwise>
                parent_id = null,
            </otherwise>
        </choose>
            sort_num = #{sortNum}
        where id = #{id}
    </update>

    <update id="updateSortNum">
        update tdw_outlines set sort_num = #{sortNum} where id = #{id}
    </update>

    <update id="batchUpdateParentId" parameterType="TdwOutlines">
        <foreach collection='list' item='item' separator=';'>
            UPDATE tdw_outlines SET parent_id = #{item.parentId} WHERE id = #{item.id}
        </foreach>
    </update>

    <update id="updateOutlineLeval1" parameterType="TdwOutlines">
        update tdw_outlines SET sort_num = sort_num + 1 WHERE bid_id = #{bidId} and parent_id IS NULL AND sort_num >= #{sortNum}
    </update>

    <update id="updateOutlineLeval1Delete" parameterType="TdwOutlines">
        update tdw_outlines SET sort_num = sort_num - 1 WHERE bid_id = #{bidId} and parent_id IS NULL AND sort_num > #{sortNum}
    </update>

    <update id="updateOutlineLeval2And3" parameterType="TdwOutlines">
        update tdw_outlines SET sort_num = sort_num + 1 WHERE parent_id = #{parentId} AND sort_num >= #{sortNum}
    </update>

    <update id="updateOutlineLeval2And3Delete" parameterType="TdwOutlines">
        update tdw_outlines SET sort_num = sort_num - 1 WHERE parent_id = #{parentId} AND sort_num > #{sortNum}
    </update>

    <delete id="deleteTdwOutlinesById" parameterType="Long">
        delete from tdw_outlines where id = #{id}
    </delete>

    <delete id="deleteTdwOutlinesByIds" parameterType="String">
        delete from tdw_outlines where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="batchDeleteByIds" parameterType="Long">
        delete from tdw_outlines where id in
        <foreach collection='list' item='id' open='(' separator=',' close=')'>
            #{id}
        </foreach>
    </delete>

</mapper>
