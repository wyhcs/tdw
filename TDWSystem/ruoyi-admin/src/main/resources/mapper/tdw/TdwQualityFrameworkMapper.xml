<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.tdw.mapper.TdwQualityFrameworkMapper">

    <resultMap type="TdwQualityFramework" id="TdwQualityFrameworkResult">
        <result property="id" column="id" />
        <result property="bidId" column="bid_id" />
        <result property="frameworkName" column="framework_name" />
        <result property="description" column="description" />
        <result property="fileName" column="file_name" />
        <result property="originalName" column="original_name" />
        <result property="fileUrl" column="file_url" />
        <result property="fileSize" column="file_size" />
        <result property="status" column="status" />
        <result property="itemCount" column="item_count" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
        <result property="delFlag" column="del_flag" />
    </resultMap>

    <sql id="selectQualityFrameworkVo">
        select framework_id as id, bid_id, framework_name, description, file_name, original_name, file_url, file_size, status, item_count,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tdw_quality_framework
    </sql>

    <select id="selectQualityFrameworkById" parameterType="Long" resultMap="TdwQualityFrameworkResult">
        <include refid="selectQualityFrameworkVo"/>
        where framework_id = #{id} and del_flag = '0'
    </select>

    <select id="selectQualityFrameworkList" parameterType="TdwQualityFramework" resultMap="TdwQualityFrameworkResult">
        <include refid="selectQualityFrameworkVo"/>
        <where>
            del_flag = '0'
            <if test="bidId != null"> and bid_id = #{bidId}</if>
            <if test="frameworkName != null and frameworkName != ''"> and framework_name like concat('%', #{frameworkName}, '%')</if>
            <if test="status != null and status != ''"> and status = #{status}</if>
        </where>
        order by create_time desc, framework_id desc
    </select>

    <select id="selectLatestByBidId" parameterType="Long" resultMap="TdwQualityFrameworkResult">
        <include refid="selectQualityFrameworkVo"/>
        where bid_id = #{bidId} and del_flag = '0'
        order by update_time desc, framework_id desc
        limit 1
    </select>

    <insert id="insertQualityFramework" parameterType="TdwQualityFramework" useGeneratedKeys="true" keyProperty="id" keyColumn="framework_id">
        insert into tdw_quality_framework
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="bidId != null">bid_id,</if>
            <if test="frameworkName != null">framework_name,</if>
            <if test="description != null">description,</if>
            <if test="fileName != null">file_name,</if>
            <if test="originalName != null">original_name,</if>
            <if test="fileUrl != null">file_url,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="status != null">status,</if>
            <if test="itemCount != null">item_count,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="bidId != null">#{bidId},</if>
            <if test="frameworkName != null">#{frameworkName},</if>
            <if test="description != null">#{description},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="originalName != null">#{originalName},</if>
            <if test="fileUrl != null">#{fileUrl},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="status != null">#{status},</if>
            <if test="itemCount != null">#{itemCount},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateQualityFramework" parameterType="TdwQualityFramework">
        update tdw_quality_framework
        <trim prefix="SET" suffixOverrides=",">
            <if test="frameworkName != null">framework_name = #{frameworkName},</if>
            <if test="bidId != null">bid_id = #{bidId},</if>
            <if test="description != null">description = #{description},</if>
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="originalName != null">original_name = #{originalName},</if>
            <if test="fileUrl != null">file_url = #{fileUrl},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="status != null">status = #{status},</if>
            <if test="itemCount != null">item_count = #{itemCount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where framework_id = #{id}
    </update>

    <update id="updateItemCount" parameterType="Long">
        update tdw_quality_framework
        set item_count = (select count(1) from tdw_quality_item where framework_id = #{id} and del_flag = '0'),
            update_time = now()
        where framework_id = #{id}
    </update>

    <delete id="deleteQualityFrameworkByIds" parameterType="Long">
        update tdw_quality_framework set del_flag = '2', update_time = now() where framework_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
