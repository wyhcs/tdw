<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.tdw.mapper.TdwDuplicateFileMapper">

    <resultMap type="TdwDuplicateFile" id="TdwDuplicateFileResult">
        <result property="id" column="id" />
        <result property="taskId" column="task_id" />
        <result property="bidId" column="bid_id" />
        <result property="fileName" column="file_name" />
        <result property="originalName" column="original_name" />
        <result property="fileUrl" column="file_url" />
        <result property="fileSize" column="file_size" />
        <result property="fileType" column="file_type" />
        <result property="parseStatus" column="parse_status" />
        <result property="createBy" column="create_by" />
        <result property="createTime" column="create_time" />
        <result property="updateBy" column="update_by" />
        <result property="updateTime" column="update_time" />
        <result property="remark" column="remark" />
        <result property="delFlag" column="del_flag" />
    </resultMap>

    <sql id="selectDuplicateFileVo">
        select id, task_id, bid_id, file_name, original_name, file_url, file_size, file_type, parse_status,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tdw_duplicate_file
    </sql>

    <select id="selectDuplicateFileById" parameterType="Long" resultMap="TdwDuplicateFileResult">
        <include refid="selectDuplicateFileVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectDuplicateFileList" parameterType="TdwDuplicateFile" resultMap="TdwDuplicateFileResult">
        <include refid="selectDuplicateFileVo"/>
        <where>
            del_flag = '0'
            <if test="taskId != null"> and task_id = #{taskId}</if>
            <if test="bidId != null"> and bid_id = #{bidId}</if>
        </where>
        order by create_time desc, id desc
    </select>

    <insert id="insertDuplicateFile" parameterType="TdwDuplicateFile" useGeneratedKeys="true" keyProperty="id">
        insert into tdw_duplicate_file(task_id, bid_id, file_name, original_name, file_url, file_size, file_type, parse_status,
                                       create_by, create_time, update_by, update_time, remark, del_flag)
        values(#{taskId}, #{bidId}, #{fileName}, #{originalName}, #{fileUrl}, #{fileSize}, #{fileType}, #{parseStatus},
               #{createBy}, #{createTime}, #{updateBy}, #{updateTime}, #{remark}, #{delFlag})
    </insert>

    <delete id="deleteByTaskIds" parameterType="Long">
        update tdw_duplicate_file set del_flag = '2', update_time = now() where task_id in
        <foreach collection="array" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>
