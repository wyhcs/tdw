<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.tdw.mapper.TdwKnowledgeBaseMapper">
    <resultMap id="TdwKnowledgeBaseResult" type="TdwKnowledgeBase">
        <id property="knowledgeId" column="knowledge_id"/>
        <result property="knowledgeName" column="knowledge_name"/>
        <result property="description" column="description"/>
        <result property="status" column="status"/>
        <result property="fileCount" column="file_count"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="remark" column="remark"/>
        <result property="delFlag" column="del_flag"/>
    </resultMap>

    <sql id="selectBaseVo">
        select knowledge_id, knowledge_name, description, status, file_count,
               create_by, create_time, update_by, update_time, remark, del_flag
        from tdw_knowledge_base
    </sql>

    <select id="selectKnowledgeBaseList" resultMap="TdwKnowledgeBaseResult">
        <include refid="selectBaseVo"/>
        <where>
            del_flag = '0'
            <if test="knowledgeName != null and knowledgeName != ''">
                and knowledge_name like concat('%', #{knowledgeName}, '%')
            </if>
            <if test="status != null and status != ''">and status = #{status}</if>
        </where>
        order by create_time desc, knowledge_id desc
    </select>

    <select id="selectKnowledgeBaseById" parameterType="Long" resultMap="TdwKnowledgeBaseResult">
        <include refid="selectBaseVo"/> where knowledge_id = #{knowledgeId} and del_flag = '0'
    </select>

    <insert id="insertKnowledgeBase" parameterType="TdwKnowledgeBase" useGeneratedKeys="true" keyProperty="knowledgeId">
        insert into tdw_knowledge_base(knowledge_name, description, status, file_count, create_by, create_time, remark, del_flag)
        values(#{knowledgeName}, #{description}, #{status}, #{fileCount}, #{createBy}, #{createTime}, #{remark}, '0')
    </insert>

    <update id="updateKnowledgeBase" parameterType="TdwKnowledgeBase">
        update tdw_knowledge_base
        <trim prefix="set" suffixOverrides=",">
            <if test="knowledgeName != null and knowledgeName != ''">knowledge_name = #{knowledgeName},</if>
            <if test="description != null">description = #{description},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="fileCount != null">file_count = #{fileCount},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where knowledge_id = #{knowledgeId}
    </update>

    <update id="deleteKnowledgeBaseById" parameterType="Long">
        update tdw_knowledge_base set del_flag = '2' where knowledge_id = #{knowledgeId}
    </update>
</mapper>
